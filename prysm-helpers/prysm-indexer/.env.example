# Required Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
IC_HOST=https://ic0.app

# Optional Configuration (defaults shown)
ROSETTA_URL=http://127.0.0.1:8081
INDEXER_RUN_MODE=daily
MAX_CONCURRENCY_CANISTER=5
MAX_CONCURRENCY_HTTP=10
TX_PAGE_SIZE_DEFAULT=1000
MAX_TRACE_DEPTH=4
CEX_BALANCE_THRESHOLD=10000.0
ENABLE_CRON=false
