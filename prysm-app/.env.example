# ==============================================================================
# REQUIRED - Your app won't work without these
# ==============================================================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API Configuration
NEXT_PUBLIC_ICPSWAP_API_BASE_URL=https://api.icpswap.com


# ==============================================================================
# OPTIONAL - App works fine without these
# ==============================================================================

# For development only
ICPSWAP_API_KEY=your_api_key_here

# Sentry Error Monitoring (Optional - for error tracking in production)
# Only needed if you want error monitoring. Get DSN from https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Upstash Redis for Rate Limiting (Optional - for API protection)
# Only needed if you want rate limiting. Get credentials from https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel environment variables (auto-set by Vercel)
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=your_commit_sha

# Node environment
NODE_ENV=development

# Internet Identity configuration (optional)
# Use NEXT_PUBLIC_II_PROVIDER_URL to override the II provider (default: https://id.ai)
NEXT_PUBLIC_II_PROVIDER_URL=
# Local II canister id for local replica (used when NEXT_PUBLIC_IC_HOST is local)
NEXT_PUBLIC_II_CANISTER_ID=
# Derivation origin for II 2.0 (custom domain or frontend canister)
NEXT_PUBLIC_II_DERIVATION_ORIGIN=
# Frontend canister id (used to derive derivation origin in production)
NEXT_PUBLIC_FRONTEND_CANISTER_ID=
